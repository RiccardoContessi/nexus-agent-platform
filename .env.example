# ── LLM ──────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-key-here

# ── Pinecone ──────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX=nexus-index

# ── PostgreSQL ────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/nexus

# ── JWT ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-string

# ── Google Calendar ───────────────────────────────
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/google_service_account.json

# ── App ───────────────────────────────────────────
APP_NAME=Nexus
APP_VERSION=1.0.0
LLM_MODEL=gpt-4o-mini
FALLBACK_MODEL=llama-3.1-8b-instant
FALLBACK_BASE_URL=https://api.groq.com/openai/v1
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVER_K=5
SUMMARY_THRESHOLD=10
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
USE_PROMPT_REPETITION=true